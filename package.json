{
  "name": "@hs-uix/stream-relay",
  "version": "0.2.0",
  "description": "Resumable, pollable stream proxy for environments where the client can't hold long connections (HubSpot UI extensions, iframe sandboxes, serverless edges).",
  "license": "MIT",
  "author": "Carter McKay",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/05bmckay/stream-relay.git"
  },
  "homepage": "https://github.com/05bmckay/stream-relay#readme",
  "keywords": [
    "stream",
    "resumable",
    "polling",
    "hubspot",
    "ui-extensions",
    "cloudflare-workers",
    "long-running",
    "llm",
    "sse-alternative"
  ],
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "sideEffects": false,
  "exports": {
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.mjs",
      "require": "./dist/client.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.mjs",
      "require": "./dist/server.js"
    },
    "./worker": {
      "types": "./dist/worker.d.ts",
      "import": "./dist/worker.mjs"
    },
    "./hono": {
      "types": "./dist/hono.d.ts",
      "import": "./dist/hono.mjs",
      "require": "./dist/hono.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run test && npm run typecheck && npm run build",
    "release:beta": "npm publish --tag beta",
    "release:patch": "npm version patch && npm publish && git push origin main --tags",
    "release:minor": "npm version minor && npm publish && git push origin main --tags",
    "release:major": "npm version major && npm publish && git push origin main --tags",
    "release:github": "node scripts/release-github.mjs"
  },
  "peerDependencies": {
    "@cloudflare/workers-types": "*",
    "hono": ">=4 <5",
    "react": ">=18 <20"
  },
  "peerDependenciesMeta": {
    "@cloudflare/workers-types": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "hono": {
      "optional": true
    }
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240909.0",
    "@hono/node-server": "^2.0.0",
    "@types/react": "^18.3.0",
    "hono": "^4.6.0",
    "react": "^18.3.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.5"
  },
  "workspaces": [
    "examples/*"
  ]
}
